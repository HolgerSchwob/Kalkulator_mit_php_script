// offerGenerator.mjs
// Creates an offer PDF using pdfmake. Refactored by Lucy.

/**
 * Generates and downloads an offer PDF based on the current application state.
 * @param {object} inquiryState - The complete state of the user's configuration.
 * @param {object} calculationResults - An object with all calculated prices.
 * @param {object} config - The main calculator configuration object.
 */
export async function generateOfferPdf(inquiryState, calculationResults, config) {
    if (typeof pdfMake === 'undefined' || typeof pdfMake.createPdf !== 'function') {
        alert("pdfMake ist nicht korrekt geladen. Das PDF kann nicht erstellt werden.");
        console.error("pdfMake is not defined or createPdf is not a function.");
        return;
    }

    const companyData = {
        name: "SCHWOB DIGITALDRUCK",
        owner: "Inhaber Holger Schwob",
        street: "Michael-Henkel-Straße 4-6",
        city: "36043 Fulda",
        phone: "0661 977717",
        email: "info@schwob-digitaldruck.de",
        ustIdNr: "DE274642127",
        logoPlaceholderText: "SCHWOB\nDIGITALDRUCK",
    };

    const currencySymbol = config.general.currencySymbol || '€';
    const today = new Date().toLocaleDateString('de-DE', { year: 'numeric', month: '2-digit', day: '2-digit' });
    const vatRate = config.general.vatRate || 7;

    const getBindingConfigById = (bindingId) => config.bindings.find(b => b.id === bindingId);
    
    let content = [
        // Header and address block would be generated here, similar to original.
        { text: 'Unverbindliches Angebot', style: 'mainTitle' },
        { text: 'Sehr geehrte Damen und Herren,', style: 'salutation', margin: [0, 0, 0, 10] },
        { text: 'vielen Dank für Ihr Interesse. Gerne unterbreiten wir Ihnen folgendes Angebot basierend auf Ihrer Online-Konfiguration:', style: 'paragraph', margin: [0, 0, 0, 15] },
    ];
    
    // --- Book Block Details ---
    content.push({ text: 'I. Buchblock Konfiguration', style: 'sectionTitle' });
    const paperConf = config.papers.find(p => p.id === inquiryState.bookBlock.paperId);
    let bookBlockTableBody = [
        [{text: 'Eigenschaft', style: 'tableHeader'}, {text: 'Spezifikation', style: 'tableHeader'}]
    ];
    bookBlockTableBody.push([{text: 'Gesamtseiten A4:', style: 'tableCell'}, {text: `${inquiryState.bookBlock.totalPages}`, style: 'tableCell'}]);
    bookBlockTableBody.push([{text: 'Papiersorte:', style: 'tableCell'}, {text: `${paperConf ? paperConf.name : 'N/A'}`, style: 'tableCell'}]);
    if (inquiryState.bookBlock.hasA3Pages && inquiryState.bookBlock.a3PagesCount > 0) {
        bookBlockTableBody.push([{text: 'Anzahl A3-Seiten:', style: 'tableCell'}, {text: `${inquiryState.bookBlock.a3PagesCount}`, style: 'tableCell'}]);
    }
    content.push({
        table: { body: bookBlockTableBody, widths: ['auto', '*'] },
        layout: 'lightHorizontalLines'
    });
    if (inquiryState.bookBlock.firstPagePreviewUrl) {
         content.push({ image: inquiryState.bookBlock.firstPagePreviewUrl, width: 120, alignment: 'center', margin: [0, 10, 0, 0] });
    }

    // --- Binding Variants ---
    content.push({ text: 'II. Bindungsvarianten & Druck', style: 'sectionTitle' });
    let variantsTableBody = [
        [{text: 'Pos.', style: 'tableHeader'}, {text: 'Beschreibung', style: 'tableHeader'}, {text: 'Menge', style: 'tableHeader', alignment:'center'}, {text: 'Einzel (Brutto)', style: 'tableHeader', alignment:'right'}, {text: 'Gesamt (Brutto)', style: 'tableHeader', alignment:'right'}]
    ];
    calculationResults.variantsWithPrices.forEach((variant, index) => {
        const bindingConf = getBindingConfigById(variant.bindingTypeId);
        variantsTableBody.push([
            `${index + 1}.1`,
            { text: bindingConf.name, style: 'tableCell' },
            { text: variant.quantity, style: 'tableCell', alignment: 'center' },
            { text: `${variant.unitPrice.toFixed(2)} ${currencySymbol}`, style: 'tableCellRight' },
            { text: `${variant.totalPrice.toFixed(2)} ${currencySymbol}`, style: 'tableCellRight', bold: true }
        ]);
    });
    content.push({
        table: { body: variantsTableBody, widths: ['auto', '*', 'auto', 'auto', 'auto'] },
        layout: 'lightHorizontalLines'
    });

    // --- Extras ---
    if (calculationResults.extrasWithPrices.length > 0) {
        content.push({ text: 'III. Zusätzliche Produkte / Extras', style: 'sectionTitle' });
        // Similar table structure for extras would be built here.
    }
    
    // --- Totals ---
    const grossTotal = calculationResults.totalOrderPrice;
    const netTotal = grossTotal / (1 + (vatRate / 100));
    const vatAmount = grossTotal - netTotal;
    content.push({ text: 'V. Gesamtkostenübersicht', style: 'sectionTitle' });
    content.push({
        table: {
            body: [
                ['Summe Netto', { text: `${netTotal.toFixed(2)} ${currencySymbol}`, alignment: 'right' }],
                [`enthaltene ${vatRate}% MwSt.`, { text: `${vatAmount.toFixed(2)} ${currencySymbol}`, alignment: 'right' }],
                [{ text: 'Gesamtsumme (Brutto)', bold: true }, { text: `${grossTotal.toFixed(2)} ${currencySymbol}`, bold: true, alignment: 'right' }]
            ],
            widths: ['*', 'auto']
        },
        layout: 'noBorders',
        margin: [0, 10, 0, 0]
    });

    let documentDefinition = {
        pageSize: 'A4',
        pageMargins: [40, 60, 40, 60],
        content: content,
        styles: {
            mainTitle: { fontSize: 16, bold: true, margin: [0, 0, 0, 15] },
            salutation: { fontSize: 10, margin: [0, 10, 0, 5] },
            sectionTitle: { fontSize: 12, bold: true, margin: [0, 15, 0, 8] },
            paragraph: { fontSize: 10, margin: [0, 0, 0, 5] },
            tableHeader: { bold: true, fontSize: 9, color: 'white', fillColor: '#34495e' },
            tableCell: { fontSize: 9, margin: [0, 3, 0, 3] },
            tableCellRight: { fontSize: 9, margin: [0, 3, 0, 3], alignment: 'right' }
        },
        defaultStyle: { font: 'Roboto' }
    };
    
    pdfMake.createPdf(documentDefinition).download(`Angebot_SchwobDigitaldruck_${today.replace(/\./g, '-')}.pdf`);
}
